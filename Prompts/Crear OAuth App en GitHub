?>

<a href="https://github.com/login/oauth/authorize?client_id=TU_CLIENT_ID&scope=repo">
  Iniciar sesión con GitHub
</a>
👉 scope=repo = acceso completo a repos
🟢 PASO 4 — Recibir el "code"
📄 callback.php
PHP
<?php
session_start();

$code = $_GET['code'];

$ch = curl_init("https://github.com/login/oauth/access_token");

curl_setopt($ch, CURLOPT_POST, true);
curl_setopt($ch, CURLOPT_POSTFIELDS, [
    "client_id" => "TU_CLIENT_ID",
    "client_secret" => "TU_CLIENT_SECRET",
    "code" => $code
]);

curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
curl_setopt($ch, CURLOPT_HTTPHEADER, ["Accept: application/json"]);

$response = curl_exec($ch);
$data = json_decode($response, true);

$_SESSION['access_token'] = $data['access_token'];

header("Location: dashboard.php");
🟢 PASO 5 — Crear dashboard
📄 dashboard.php
PHP
<?php
session_start();

if (!isset($_SESSION['access_token'])) {
    die("No autorizado");
}

$token = $_SESSION['access_token'];

$ch = curl_init("https://api.github.com/user/repos");

curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
curl_setopt($ch, CURLOPT_HTTPHEADER, [
    "Authorization: Bearer $token",
    "User-Agent: MiApp"
]);

$response = curl_exec($ch);
$repos = json_decode($response, true);
?>

<h1>Tus repositorios</h1>

<ul>
<?php foreach ($repos as $repo): ?>
    <li><?= $repo['name'] ?></li>
<?php endforeach; ?>
</ul>
